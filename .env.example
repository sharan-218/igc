# ── Infrastructure ──────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/"
DATABASE_URL="postgresql://user:pass@localhost:5432/web_intelligence"
STORAGE_URL="supabase-url"

# ── Crawler ─────────────────────────────────────────────────────────────────────
CONCURRENCY=10                   # BullMQ worker concurrency per process
JS_RENDER_ENABLED=false          # Enable Playwright JS rendering (requires playwright install)
JS_BROWSER_POOL_SIZE=2           # Number of Chromium instances in pool
SEED_FROM_SITEMAP=true           # Auto-discover URLs from sitemap.xml on depth-0
QUALITY_THRESHOLD=25              # Min quality score (0-100) to save chunks

# ── Proxy rotation ──────────────────────────────────────────────────────────────
# Set to "pool" to use PROXY_URLS, or "direct" to bypass proxies entirely.
PROXY_MODE=direct
# Comma-separated list of proxy URLs. Used only when PROXY_MODE=pool.
PROXY_URLS=""
# Example: PROXY_URLS="http://user:pass@proxy1:8080,http://user:pass@proxy2:8080"

# ── Embeddings ──────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai        # openai | cohere | local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=50
EMBEDDING_CONCURRENCY=5
EMBEDDING_POLL_MS=5000

# Required for EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=""

# Required for EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=""

# Required for EMBEDDING_PROVIDER=local (e.g. Ollama)
LOCAL_EMBEDDING_URL="http://localhost:11434/api/embed"
