{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["packages/core/src/*"],
      "@schemas/*": ["packages/schemas/src/*", "packages/schemas/*"],
      "@utils/*": ["packages/utils/src/*", "packages/utils/*"],
      "@crawler/*": ["packages/crawler/src/*", "packages/crawler/*"],
      "@storage/*": ["packages/storage/src/*", "packages/storage/*"],
      "@core": ["packages/core/src/index.ts", "packages/core/index.ts"],
      "@schemas": ["packages/schemas/src/index.ts", "packages/schemas/index.ts"],
      "@utils": ["packages/utils/src/index.ts", "packages/utils/index.ts"],
      "@crawler": ["packages/crawler/src/index.ts", "packages/crawler/index.ts"],
      "@storage": ["packages/storage/src/index.ts", "packages/storage/index.ts"]
    }


  }
}
